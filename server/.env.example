# Copy this file to .env and fill in real values.
# NEVER commit the real .env file — it holds secret keys.

PORT=5000

# Frontend origin allowed to call this API (Vite dev server by default)
CLIENT_ORIGIN=http://localhost:5173

# Supabase — Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key

# Email addresses
# "From" must be on a domain you've verified in Resend. Until you verify
# h2softskills.in, Resend's shared "onboarding@resend.dev" sender works for testing.
MAIL_FROM=H2 Softskills <onboarding@resend.dev>
MAIL_TO=dshivang2002@gmail.com

# --- Admin dashboard (newsletter subscribers + broadcast) -----------------
# The email you'll log in with at /admin/login.
ADMIN_EMAIL=admin@h2softskills.in

# NEVER put a plain-text password here. Generate a bcrypt hash with:
#   cd server && npm run hash-password -- "your-chosen-password"
# then paste the printed hash below.
ADMIN_PASSWORD_HASH=replace-with-generated-bcrypt-hash

# Random long string used to sign admin login sessions (JWTs).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
